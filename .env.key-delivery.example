# Copy to .env for local testing, or set these in Railway → Variables

# ----- Stripe (Dashboard → Developers → API keys & Webhooks) ----------------
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----- Resend (resend.com → API Keys) ---------------------------------------
RESEND_API_KEY=re_xxx
KEY_EMAIL_FROM=Project Tempest <keys@yourdomain.com>
KEY_EMAIL_REPLY_TO=support@yourdomain.com

# ----- Supabase (Project Settings → API) ------------------------------------
# Use the *service_role* key, not the anon key. Never put service_role in
# anything that runs in the browser.
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ----- License key encryption (at-rest in Supabase) -------------------------
# Generate once with:  node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# Then store the SAME value on Railway and in your local .env.  Rotating it
# requires re-encrypting every row in the keys table.
KEY_ENCRYPTION_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# ----- CORS origins for /api/stock (comma separated) ------------------------
# Defaults to projectempest.xyz + localhost dev ports if unset.
# ALLOWED_ORIGINS=https://projectempest.xyz,https://www.projectempest.xyz

# ----- Server (Railway sets PORT automatically) -----------------------------
PORT=8787
NODE_ENV=production

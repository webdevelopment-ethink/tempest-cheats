# Copy to .env for local testing, or set these in Railway → Variables

# Stripe (Dashboard → Developers → API keys & Webhooks)
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Resend (resend.com → API Keys)
RESEND_API_KEY=re_xxx
KEY_EMAIL_FROM=Project Tempest <keys@yourdomain.com>
KEY_EMAIL_REPLY_TO=support@yourdomain.com

# Team admin (browser login at /admin) — share with 3–4 teammates
ADMIN_PASSWORD=choose-a-strong-shared-password
ADMIN_SESSION_SECRET=optional-random-string-for-extra-security

# Database — use /data/keys.db on Railway when you attach a volume
KEY_DB_PATH=./data/keys.db

# Server (Railway sets PORT automatically)
PORT=8787
NODE_ENV=production
